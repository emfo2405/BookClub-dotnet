@model BookClub.Models.ChapterModel

@{
    ViewData["Title"] = "Create";
}

<h1 class="text-center m-5">Lägg till kapitel</h1>

<hr />
<div class="row form">
    <div class="col-md-4 formContent">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Title" class="control-label">Titel:</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Number" class="control-label">Nummer:</label>
                <input asp-for="Number" class="form-control" />
                <span asp-validation-for="Number" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BookModelId" class="control-label">Bok:</label>
                <select asp-for="BookModelId" class ="form-control" asp-items="ViewBag.BookModelId"></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Skapa" class="update updateEdit" />
            </div>
        </form>
    </div>
</div>

<div class="editBack">
    <a asp-action="Index">Visa alla kapitel</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
