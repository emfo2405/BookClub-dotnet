@model BookClub.Models.ReviewModel

@{
    ViewData["Title"] = "Edit";
}

<h1 class="text-center m-5">Uppdatera inlägget</h1>


<hr />
<div class="row form">
    <div class="col-md-4 formContent">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="UserName" />
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            <div class="form-group">
                <label asp-for="Review" class="control-label"></label>
                <input asp-for="Review" class="form-control" />
                <span asp-validation-for="Review" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Comment" class="control-label"></label>
                <input asp-for="Comment" class="form-control" />
                <span asp-validation-for="Comment" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BookModelId" class="control-label"></label>
                <select asp-for="BookModelId" class="form-control" asp-items="ViewBag.BookModelId"></select>
                <span asp-validation-for="BookModelId" class="text-danger"></span>
            </div>
            <div class="form-group mb-5">
                <input type="submit" value="Uppdatera" class="update updateEdit" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
