@model BookClub.Models.ReviewModel

@{
    ViewData["Title"] = "Create";
}

<h1 class="text-center m-5">Lämna ett betyg</h1>

<hr />
<div class="row form">
    <div class="col-md-4 formContent">
        <form asp-action="Create">
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Review" class="control-label">Betyg:</label>
                <input asp-for="Review" class="form-control" />
                <span asp-validation-for="Review" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Comment" class="control-label">Kommentar:</label>
                <input asp-for="Comment" class="form-control" />
                <span asp-validation-for="Comment" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BookModelId" class="control-label">Bok:</label>
                <select asp-for="BookModelId" class ="form-control" asp-items="ViewBag.BookModelId"></select>
            </div>
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            <div class="form-group">
                <input type="submit" value="Skapa" class="update updateEdit"/>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
