@model BookClub.Models.AuthorModel

@{
    ViewData["Title"] = "Uppdatera författare";
}

<h1 class="text-center m-5">Uppdatera information</h1>

<h4 class="text-center">@Model.Name</h4>
<hr />
<div class="row form">
    <div class="col-md-4 formContent">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="Name" class="control-label">Namn:</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description" class="control-label">Beskrivning:</label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Country" class="control-label">Land:</label>
                <input asp-for="Country" class="form-control" />
                <span asp-validation-for="Country" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Uppdatera" class="update updateEdit" />
            </div>
        </form>
    </div>
</div>

<div class="editBack">
    <a asp-action="Index">Visa alla författare</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
