@model BookClub.Models.AuthorModel

@{
    ViewData["Title"] = "Details";
}

<h1 class="text-center m-5">Om författaren</h1>

<div>
    <h4 class="text-center">@Model.Name</h4>

    <hr />
    <div class="authorDetails">
    <span class="material-symbols-outlined w-100" id="personImg">article_person</span>
    <h5 class="w-75 d-block mx-auto">Beskrivning</h5>    
    <p class="w-75 d-block mx-auto">@Model.Description</p>
    <h5 class="w-75 d-block mx-auto">Land</h5>
    <p class="w-75 d-block mx-auto">@Model.Country</p>
    </div>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="update updateEdit text-center d-block mx-auto">Uppdatera</a> |
    <a asp-action="Index" class="editBack">Visa alla författare</a>
</div>
