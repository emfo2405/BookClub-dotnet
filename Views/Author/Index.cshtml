@model IEnumerable<BookClub.Models.AuthorModel>

@{
    ViewData["Title"] = "Index";
}

<h1 class="text-center m-5">Våra författare</h1>

<div class="allAuthors">
@foreach (var item in Model.OrderBy(a => a.Name) ) {
    <div class="authorProfile">
    <span class="material-symbols-outlined w-100" id="personImgIndex">article_person</span>
        <h4 class="text-center">@item.Name</h4>
        <h5 class="text-center">@item.Country</h5>
        <div>
            <button class="showAuthorInfo" data-bs-toggle="collapse" data-bs-target="#description-@item.Id">Visa beskrivning <span class="material-symbols-outlined align-middle">keyboard_arrow_down</span></button>
            <p class="collapse descriptionViewIndex" id="description-@item.Id">@item.Description</p>
        </div>
                <a asp-action="Details" asp-route-id="@item.Id" class="mt-2 showInfo text-center">Visa författare</a> 

                @if(User.IsInRole("Admin")) {
                <div class="d-flex mt-4 text-center">
                <a asp-action="Edit" asp-route-id="@item.Id" class="update">Uppdatera</a> 
                <a asp-action="Delete" asp-route-id="@item.Id" class="delete">Radera</a>    
                </div>
                   
                }
</div>                
}
</div>
<p>
    @if(User.IsInRole("Admin")) {
    <a asp-action="Create" class="showBooksBtn mx-auto d-block mt-4 mb-5">Lägg till en författare</a>        
    }

</p>