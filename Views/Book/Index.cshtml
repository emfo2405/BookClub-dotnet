@model IEnumerable<BookClub.Models.BookModel>

@{
    ViewData["Title"] = "Våra böcker";
}

<h1 class="text-center m-5">Våra böcker</h1>

<p class="text-center p-2">
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create">Lägg till en ny bok</a>
    }
    
</p>

<div class="bookList">
@foreach (var item in Model) {
    <div>
    <img class="bookDisplayImg" src="@item.Image" />
    <h3>@Html.DisplayFor(modelItem => item.Title) <br /> @Html.DisplayFor(modelItem => item.Author.Name)</h3>
    <h4>@Html.DisplayFor(modelItem => item.Year)</h4>
    <p> ⭐ @(item.AverageRating?.ToString("0.0")
        ?? "-")
    </p>
    <a class="btn" type="button" data-bs-toggle="collapse" data-bs-target="#description-@item.Id">Visa beskrivning</a> 
    <div class="collapse" id="description-@item.Id">
    <p class="text-start p-4">@Html.DisplayFor(modelItem => item.Description)</p>        
    </div>
    <br />

@if (User.IsInRole("Admin"))
{
    <a asp-action="Edit" asp-route-id="@item.Id">Uppdatera</a>
    <a asp-action="Delete" asp-route-id="@item.Id">Radera</a>
}
    
    <a asp-action="Details" asp-route-id="@item.Id">Visa information</a>
    
</div>
}
</div>
