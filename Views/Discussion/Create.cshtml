@model BookClub.Models.DiscussionModel

@{
    ViewData["Title"] = "Create";
}

<h1 class="text-center m-5">Delta i diskussionen</h1>

<hr />
<div class="row form">
    <div class="col-md-4 formContent">
    <!--Formulär för att kunna skapa ett nytt diskussionsinlägg med titel, innehåll och kapitel-id-->
        <form asp-action="Create">
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            <input type="hidden" name="bookId" value="@ViewData["BookId"]" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Title" class="control-label">Titel:</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Content" class="control-label">Kommentar:</label>
                <input asp-for="Content" class="form-control" />
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ChapterModelId" class="control-label">Kapitel:</label>
                <select asp-for="ChapterModelId" class ="form-control" asp-items="ViewBag.ChapterModelId"></select>
            </div>
            <div class="form-group">
            <!--Knapp för att skicka in formuläret-->
                <input type="submit" value="Skapa" class="update updateEdit" />
            </div>
        </form>
    </div>
</div>


    @{
      if(ViewBag.responseMessage != null) {
<!--Om AI-modereringen genererar en bedömning visas den här med bedömning och motivation-->
<div class="mx-auto mt-4 border border-info bg-info bg-opacity-10 p-4 aiResponse">        
        <p class="fw-bold">@ViewBag.ResponseMessage</p>
        <p>@ViewBag.Motivation</p>
</div>        
      }  
    }
    
<div class="d-flex w-50 mx-auto">
    @if(!string.IsNullOrEmpty(ViewData["ReturnUrl"]?.ToString())) {
        <!--Om en url har sparats från föregående sida visas den i länken här -->
        <a class="editBack mx-auto addBookBtn" href="@ViewData["ReturnUrl"]">Visa föregående sida</a>
    }
    <!--En länk för att visa alla böcker visas här-->
        <a class="editBack mx-auto addBookBtn" asp-area="" asp-controller="Book" asp-action="Index">Visa alla böcker</a>
</div>



@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
